---
import type { MarkdownHeading } from "astro";
import { TOC_IDS, TOC_LABELS } from "../lib/config";
import { renderTocHtml } from "../lib/render";

interface Props {
  tocMode?: "auto" | "off";
  headings?: MarkdownHeading[];
}

const { tocMode = "auto", headings = [] }: Props = Astro.props;
const hidden = tocMode === "off";
const tocHtml = hidden ? "" : renderTocHtml(headings);
---

<aside class="toc-sidebar" id={TOC_IDS.sidebar} aria-labelledby={TOC_IDS.heading} hidden={hidden}>
  <button
    class="toc-sidebar__toggle"
    id={TOC_IDS.toggle}
    aria-label={TOC_LABELS.open}
    aria-expanded="false"
    aria-controls={TOC_IDS.panel}
    type="button"
  >
    <svg class="toc-sidebar__toggle-icon toc-sidebar__toggle-icon--open" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
      <path d="M3 4h18v2H3V4zm0 7h12v2H3v-2zm0 7h18v2H3v-2z"></path>
    </svg>
    <svg class="toc-sidebar__toggle-icon toc-sidebar__toggle-icon--close" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
      <path d="M18.3 5.71a1 1 0 0 0-1.41 0L12 10.59 7.11 5.7A1 1 0 0 0 5.7 7.11L10.59 12 5.7 16.89a1 1 0 1 0 1.41 1.41L12 13.41l4.89 4.89a1 1 0 0 0 1.41-1.41L13.41 12l4.89-4.89a1 1 0 0 0 0-1.4z"></path>
    </svg>
  </button>

  <div class="toc-sidebar__backdrop" id={TOC_IDS.backdrop} aria-hidden="true"></div>

  <div class="toc-sidebar__panel" id={TOC_IDS.panel} role="region" aria-labelledby={TOC_IDS.heading}>
    <div class="toc-sidebar__header">
      <h2 class="toc-sidebar__title" id={TOC_IDS.heading}>{TOC_LABELS.title}</h2>
      <button class="toc-sidebar__close" id={TOC_IDS.close} aria-label={TOC_LABELS.close} type="button">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M18.3 5.71a1 1 0 0 0-1.41 0L12 10.59 7.11 5.7A1 1 0 0 0 5.7 7.11L10.59 12 5.7 16.89a1 1 0 1 0 1.41 1.41L12 13.41l4.89 4.89a1 1 0 0 0 1.41-1.41L13.41 12l4.89-4.89a1 1 0 0 0 0-1.4z"></path>
        </svg>
      </button>
    </div>

    <div class="toc-sidebar__progress" aria-hidden="true">
      <div class="toc-sidebar__progress-bar" id={TOC_IDS.progress}></div>
    </div>

    <nav class="toc-sidebar__nav" id={TOC_IDS.nav} aria-label={TOC_LABELS.nav}>
      {tocHtml && <Fragment set:html={tocHtml} />}
    </nav>
  </div>
</aside>
