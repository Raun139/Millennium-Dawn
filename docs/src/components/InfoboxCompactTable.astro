---
interface Stat { label: string; value: string }
interface Group { section: string; stats: Stat[] }

interface Props {
  group: Group;
  columns: string[];
  label: string;
}

const { group, columns, label }: Props = Astro.props;

function statValue(labels: string[]): string {
  const match = (group.stats ?? []).find((item) => labels.includes(item.label));
  return match?.value ?? "-";
}
---

<div class="wiki-infobox__compact-table-wrap">
  <table class="wiki-infobox__compact-table" aria-label={label}>
    <thead>
      <tr>
        {columns.map((col) => (
          <th>{col}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      <tr>
        {columns.map((col) => (
          <td>{statValue([col, col.replace(/\.$/, "")])}</td>
        ))}
      </tr>
    </tbody>
  </table>
</div>
