---
import ResponsiveImage from "./ResponsiveImage.astro";

interface RoadmapImage {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: "lazy" | "eager";
}

interface Roadmap {
  title: string;
  paragraphs?: string[];
  image: RoadmapImage;
}

interface Props {
  roadmaps: Roadmap[];
}

const { roadmaps }: Props = Astro.props;
---

<h2>Roadmap Images</h2>
{roadmaps.map((roadmap) => (
  <article>
    <h3>{roadmap.title}</h3>
    {(roadmap.paragraphs ?? []).map((paragraph) => (
      <p>{paragraph}</p>
    ))}
    <ResponsiveImage
      src={roadmap.image.src}
      alt={roadmap.image.alt}
      width={roadmap.image.width}
      height={roadmap.image.height}
      loading={roadmap.image.loading}
    />
  </article>
))}
