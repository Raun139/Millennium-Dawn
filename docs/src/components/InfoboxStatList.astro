---
interface Stat { label: string; value: string }

interface Props {
  stats: Stat[];
  excludeLabels?: string[];
}

const { stats, excludeLabels = [] }: Props = Astro.props;
const filtered = (stats || []).filter((stat) => !excludeLabels.includes(stat.label));
---

<ul class="wiki-infobox__stats">
  {filtered.map((stat) => (
    <li>
      <span>{stat.label}</span>
      <strong>{stat.value}</strong>
    </li>
  ))}
</ul>
