---
import { getEntry, render } from "astro:content";
import MarkdownDocLayout from "../../layouts/MarkdownDocLayout.astro";
import { CONTENT_PAGE_ROUTES } from "../../lib/page-meta";

const entry = await getEntry("pages", "getting-started");
if (!entry) {
  throw new Error("Missing pages/getting-started content entry");
}

const { Content, headings } = await render(entry);
---

<MarkdownDocLayout entry={entry} canonicalPath={CONTENT_PAGE_ROUTES["getting-started"]} headings={headings}>
  <Content />
</MarkdownDocLayout>
