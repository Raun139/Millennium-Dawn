---
import { getEntry, render } from "astro:content";
import MarkdownDocLayout from "../../layouts/MarkdownDocLayout.astro";
import { CONTENT_PAGE_ROUTES } from "../../lib/page-meta";

const entry = await getEntry("pages", "faq");
if (!entry) {
  throw new Error("Missing pages/faq content entry");
}

const { Content, headings } = await render(entry);
---

<MarkdownDocLayout entry={entry} canonicalPath={CONTENT_PAGE_ROUTES.faq} headings={headings}>
  <Content />
</MarkdownDocLayout>
