---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SearchableIndex } from "../../features/searchable-index";
import { STATIC_PAGE_META } from "../../lib/page-meta";
import { toCardItem } from "../../lib/cards";
import { getResourcePath } from "../../lib/content-routes";

const resourceEntries = (await getCollection("resources"))
  .slice()
  .sort((a, b) => {
    const ao = a.data.order ?? Number.MAX_SAFE_INTEGER;
    const bo = b.data.order ?? Number.MAX_SAFE_INTEGER;
    if (ao !== bo) return ao - bo;
    return a.data.title.localeCompare(b.data.title);
  });

const pageMeta = STATIC_PAGE_META.resources;
const cards = resourceEntries.map((entry) => toCardItem(entry, { url: getResourcePath(entry) }));
---

<BaseLayout
  title={pageMeta.title}
  pageId={pageMeta.pageId}
  description={pageMeta.description}
  canonicalPath={pageMeta.canonicalPath}
  toc="off"
>
  <h1>Development Resources</h1>
  <p>This is a non-exhaustive list of team-based resources for Millennium Dawn.</p>

  <SearchableIndex
    items={cards}
    ariaLabel="Team development resources"
    pageSize={8}
    filterLabel="Search"
    filterPlaceholder="Type to filter..."
    emptyText="No resources matched your search."
  />
</BaseLayout>
