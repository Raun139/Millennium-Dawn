---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import MarkdownDocLayout from "../../layouts/MarkdownDocLayout.astro";
import { getDevDiaryPath, getDevDiarySlug } from "../../lib/content-routes";
import { buildMarkdownDocStaticPaths, renderMarkdownDocEntry } from "../../lib/markdown-doc-entry";

interface Props {
  entry: CollectionEntry<"devDiaries">;
}

export const getStaticPaths: GetStaticPaths = async () => {
  return buildMarkdownDocStaticPaths("devDiaries", getDevDiarySlug);
};

const { entry }: Props = Astro.props;
const { Content, headings } = await renderMarkdownDocEntry(entry);
---

<MarkdownDocLayout entry={entry} canonicalPath={getDevDiaryPath(entry)} headings={headings}>
  <Content />
</MarkdownDocLayout>
