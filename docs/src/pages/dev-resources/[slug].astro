---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import MarkdownDocLayout from "../../layouts/MarkdownDocLayout.astro";
import { getEntryBaseId, getResourcePath } from "../../lib/content-routes";
import { buildMarkdownDocStaticPaths, renderMarkdownDocEntry } from "../../lib/markdown-doc-entry";

interface Props {
  entry: CollectionEntry<"resources">;
}

export const getStaticPaths: GetStaticPaths = async () => {
  return buildMarkdownDocStaticPaths("resources", getEntryBaseId);
};

const { entry }: Props = Astro.props;
const { Content, headings } = await renderMarkdownDocEntry(entry);
---

<MarkdownDocLayout entry={entry} canonicalPath={getResourcePath(entry)} headings={headings}>
  <Content />
</MarkdownDocLayout>
