---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import MarkdownDocLayout from "../../layouts/MarkdownDocLayout.astro";
import { getChangelogPath, getEntryBaseId } from "../../lib/content-routes";
import { buildMarkdownDocStaticPaths, renderMarkdownDocEntry } from "../../lib/markdown-doc-entry";

interface Props {
  entry: CollectionEntry<"changelogSections">;
}

export const getStaticPaths: GetStaticPaths = async () => {
  return buildMarkdownDocStaticPaths("changelogSections", getEntryBaseId);
};

const { entry }: Props = Astro.props;
const { Content, headings } = await renderMarkdownDocEntry(entry);
---

<MarkdownDocLayout entry={entry} canonicalPath={getChangelogPath(entry)} headings={headings} toc="off">
  <Content />
</MarkdownDocLayout>
